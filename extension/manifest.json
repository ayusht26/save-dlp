{
  "manifest_version": 3,
  "name": "Save-DLP",
  "version": "1.1",
  "description": "A private video downloader for friends.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://save-dlp-production.up.railway.app/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "savedlp@yourcustomname.com",
      "strict_min_version": "109.0"
    }
  }
}
