{
  "manifest_version": 3,
  "name": "save-dlp",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://save-dlp-production.up.railway.app/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
